{
  "topics": [
    {
      "topic": "财务指标",
      "entity_type": "FinancialIndicator",
      "concepts": [
        {
          "name": "ROE",
          "full_name": "净资产收益率",
          "definition": "净利润与平均净资产的比率",
          "formula": "净利润 / 平均净资产",
          "unit": "%",
          "meaning": "衡量公司使用股东资金创造利润的能力，反映股东权益的收益水平",
          "category": "盈利能力指标"
        },
        {
          "name": "ROA",
          "full_name": "总资产收益率",
          "definition": "净利润与平均总资产的比率",
          "formula": "净利润 / 平均总资产",
          "unit": "%",
          "meaning": "衡量公司利用全部资产获取利润的能力，反映资产利用效率",
          "category": "盈利能力指标"
        },
        {
          "name": "Gross Margin",
          "full_name": "销售毛利率",
          "definition": "毛利与营业收入的比率",
          "formula": "(营业收入 - 营业成本) / 营业收入",
          "unit": "%",
          "meaning": "衡量产品本身的盈利能力，反映扣除直接成本后的利润空间",
          "category": "盈利能力指标"
        },
        {
          "name": "Net Margin",
          "full_name": "销售净利率",
          "definition": "净利润与营业收入的比率",
          "formula": "净利润 / 营业收入",
          "unit": "%",
          "meaning": "衡量公司最终获利能力，反映每一元销售收入带来的净利润",
          "category": "盈利能力指标"
        },
        {
          "name": "PE",
          "full_name": "市盈率",
          "definition": "股票价格与每股收益的比率",
          "formula": "股价 / 每股收益 (EPS)",
          "unit": "倍",
          "meaning": "衡量投资回收期，反映市场对公司未来盈利增长的预期",
          "category": "估值指标"
        },
        {
          "name": "PB",
          "full_name": "市净率",
          "definition": "股票价格与每股净资产的比率",
          "formula": "股价 / 每股净资产",
          "unit": "倍",
          "meaning": "衡量股价相对于账面价值的倍数，适用于重资产行业估值",
          "category": "估值指标"
        },
        {
          "name": "PS",
          "full_name": "市销率",
          "definition": "股票价格与每股销售收入的比率",
          "formula": "市值 / 营业收入",
          "unit": "倍",
          "meaning": "衡量股价相对于销售收入的倍数，适用于尚未盈利的高成长公司",
          "category": "估值指标"
        },
        {
          "name": "PC",
          "full_name": "市现率",
          "definition": "股票价格与每股现金流的比率",
          "formula": "股价 / 每股经营现金流",
          "unit": "倍",
          "meaning": "衡量股价相对于现金流的倍数，反映公司现金流创造能力的估值",
          "category": "估值指标"
        },
        {
          "name": "Revenue Growth",
          "full_name": "营业收入增长率",
          "definition": "本期营业收入增长额与上期营业收入的比率",
          "formula": "(本期营收 - 上期营收) / 上期营收",
          "unit": "%",
          "meaning": "衡量公司业务规模的扩张速度，反映市场占有率的变化",
          "category": "成长能力指标"
        },
        {
          "name": "Net Profit Growth",
          "full_name": "净利润增长率",
          "definition": "本期净利润增长额与上期净利润的比率",
          "formula": "(本期净利 - 上期净利) / 上期净利",
          "unit": "%",
          "meaning": "衡量公司盈利能力的增长速度，反映成长性的核心指标",
          "category": "成长能力指标"
        },
        {
          "name": "Total Asset Turnover",
          "full_name": "总资产周转率",
          "definition": "营业收入与平均总资产的比率",
          "formula": "营业收入 / 平均总资产",
          "unit": "次",
          "meaning": "衡量公司全部资产的使用效率，反映资产周转速度",
          "category": "营运能力指标"
        },
        {
          "name": "Inventory Turnover",
          "full_name": "存货周转率",
          "definition": "营业成本与平均存货的比率",
          "formula": "营业成本 / 平均存货",
          "unit": "次",
          "meaning": "衡量存货变现速度，反映销售能力和存货管理水平",
          "category": "营运能力指标"
        },
        {
          "name": "Receivables Turnover",
          "full_name": "应收账款周转率",
          "definition": "营业收入与平均应收账款的比率",
          "formula": "营业收入 / 平均应收账款",
          "unit": "次",
          "meaning": "衡量应收账款回收速度，反映资金占用情况和信用政策",
          "category": "营运能力指标"
        },
        {
          "name": "Debt-to-Asset",
          "full_name": "资产负债率",
          "definition": "总负债与总资产的比率",
          "formula": "总负债 / 总资产",
          "unit": "%",
          "meaning": "衡量公司财务杠杆水平和长期偿债能力，反映财务风险",
          "category": "偿债能力指标"
        },
        {
          "name": "Current Ratio",
          "full_name": "流动比率",
          "definition": "流动资产与流动负债的比率",
          "formula": "流动资产 / 流动负债",
          "unit": "倍",
          "meaning": "衡量公司短期偿债能力，反映每一元流动负债有多少流动资产作为保障",
          "category": "偿债能力指标"
        },
        {
          "name": "Quick Ratio",
          "full_name": "速动比率",
          "definition": "速动资产与流动负债的比率",
          "formula": "(流动资产 - 存货) / 流动负债",
          "unit": "倍",
          "meaning": "衡量公司立即偿还短期债务的能力，比流动比率更严格",
          "category": "偿债能力指标"
        },
        {
          "name": "Interest Coverage",
          "full_name": "利息保障倍数",
          "definition": "息税前利润与利息费用的比率",
          "formula": "息税前利润 (EBIT) / 利息费用",
          "unit": "倍",
          "meaning": "衡量公司支付利息的能力，反映长期偿债安全性",
          "category": "偿债能力指标"
        },
        {
          "name": "Dividend Yield",
          "full_name": "股息率",
          "definition": "每股股息与股票价格的比率",
          "formula": "每股股息 / 股价",
          "unit": "%",
          "meaning": "衡量投资回报中的现金分红部分，反映公司的分红意愿和能力",
          "category": "其他重要指标"
        },
        {
          "name": "PEG",
          "full_name": "市盈率相对盈利增长比率",
          "definition": "市盈率与净利润增长率的比率",
          "formula": "市盈率 (PE) / 净利润增长率",
          "unit": "倍",
          "meaning": "衡量估值与成长性的匹配度，用于判断高成长公司估值是否合理",
          "category": "其他重要指标"
        }
      ],
