{
  "_note": "Example LLM API Configuration - Copy this file to llm.json and add your API keys",
  "_instructions": "Supported providers: yunnetC (gpt-5.3-codex), yunnet (claude), deepseek, openai",
  "yunnetC": {
    "model": "gpt-5.3-codex",
    "api_base": "https://api.yunnet.top/v1",
    "api_key": "YOUR_API_KEY_HERE",
    "temperature": 0.5,
    "max_tokens": 4096
  },
  "yunnet": {
    "model": "claude-opus-4-6",
    "api_base": "https://api.yunnet.top/v1",
    "api_key": "YOUR_API_KEY_HERE",
    "temperature": 0.7,
    "max_tokens": 4096
  },
  "deepseek": {
    "model": "deepseek-chat",
    "api_base": "https://api.deepseek.com",
    "api_key": "YOUR_API_KEY_HERE",
    "temperature": 0.5,
    "max_tokens": 4096
  },
  "openai": {
    "model": "gpt-4o-mini",
    "api_base": "https://api.openai.com/v1",
    "api_key": "YOUR_API_KEY_HERE",
    "temperature": 0.3,
    "max_tokens": 2048
  }
}
